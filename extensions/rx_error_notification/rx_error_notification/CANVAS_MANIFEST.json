{
    "sdk_version": "0.123.1",
    "plugin_version": "0.2.1",
    "name": "rx_error_notification",
    "description": "Creates a task assigned to the prescriber when a prescription returns an error status",
    "tags": {},
    "license": "MIT",
    "readme": "../README.md",
    "components": {
        "handlers": [
            {
                "class": "rx_error_notification.rx_error_handler:RxErrorNotificationHandler",
                "description": "Listens for PRESCRIPTION_ERRORED events and creates tasks for the prescriber",
                "data_access": {
                    "event": "",
                    "read": ["Prescription", "Patient", "Staff", "Medication"],
                    "write": []
                }
            }
        ]
    }
}
