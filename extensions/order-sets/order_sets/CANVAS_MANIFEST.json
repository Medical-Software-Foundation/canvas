{
    "sdk_version": "0.1.4",
    "plugin_version": "0.0.32",
    "name": "order_sets",
    "description": "Predefined order sets for labs, imaging, and POC in-office tests. Select bundles of orders with one click from the patient chart.",
    "url_permissions": [],
    "components": {
        "protocols": [
            {
                "class": "order_sets.api.endpoints:OrderSetsAPI",
                "description": "API endpoints for order set management and execution",
                "data_access": {
                    "event": "",
                    "read": [
                        "LabPartner",
                        "LabPartnerTest",
                        "Staff",
                        "StaffRole",
                        "Note",
                        "CurrentNoteStateEvent",
                        "ChargeDescriptionMaster"
                    ],
                    "write": []
                }
            }
        ],
        "applications": [
            {
                "class": "order_sets.applications.order_sets_app:OrderSetsApp",
                "name": "Order Sets",
                "description": "Browse and apply predefined order sets for labs and imaging",
                "scope": "patient_specific",
                "icon": "assets/icon.png"
            },
            {
                "class": "order_sets.applications.order_sets_admin_app:OrderSetsAdminApp",
                "name": "Order Sets Admin",
                "description": "Manage practice-wide and personal order sets",
                "scope": "global",
                "icon": "assets/icon.png"
            }
        ],
        "commands": [],
        "content": [],
        "effects": [],
        "views": []
    },
    "secrets": [],
    "custom_data": {
        "namespace": "canvas_medical__order_sets",
        "access": "read_write"
    },
    "tags": {},
    "references": [],
    "license": "MIT",
    "diagram": false,
    "readme": "./README.md"
}
