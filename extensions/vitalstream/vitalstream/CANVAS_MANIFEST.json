{
    "sdk_version": "0.85.0",
    "plugin_version": "1.1.0",
    "name": "vitalstream",
    "description": "An integration for the VitalStream device by Caretaker",
    "components": {
        "protocols": [
            {
                "class": "vitalstream.routes.vitalstream_api:CaretakerPortalAPI",
                "description": "API to receive readings from the vitalstream device"
            },
            {
                "class": "vitalstream.routes.vitalstream_ui_api:VitalstreamUIAPI",
                "description": "API to provide the UI for this integration"
            },
            {
                "class": "vitalstream.applications.vitalstream_ui:VitalstreamUILauncher",
                "description": "ActionButton launcher to launch the UI"
            },
            {
                "class": "vitalstream.channels.live_observations:LiveObservationsChannel",
                "description": "Websocket for the integration UI"
            }
        ],
        "commands": [
            {
                "name": "SpravatoVitals",
                "label": "Spravato Vitals",
                "schema_key": "spravatoVitals",
                "section": "objective"
            },
            {
                "name": "VitalstreamSummary",
                "label": "VitalStream Summary",
                "schema_key": "vitalstreamSummary",
                "section": "objective"
            }
        ],
        "content": [],
        "effects": [],
        "views": []
    },
    "secrets": ["AUTHORIZED_SERIAL_NUMBERS", "ENABLE_MOCK_VITALS"],
    "tags": {},
    "references": [],
    "license": "",
    "diagram": false,
    "readme": "./README.md"
}
