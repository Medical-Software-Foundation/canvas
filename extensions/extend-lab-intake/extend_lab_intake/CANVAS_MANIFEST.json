        "protocols": [
            {
                "class": "extend_lab_intake.protocols.task_completion:TaskCompletionHandler",
                "description": "Notifies configured callback when lab intake task completes"
            },
            {
                "class": "extend_lab_intake.api.inbound_fax:InboundFaxAPI",
                "description": "API endpoint for receiving lab report PDFs via POST"
            }
        ],
        "applications": [
            {
                "class": "extend_lab_intake.applications.document_queue:DocumentQueueApplication",
                "name": "Lab Parser",
