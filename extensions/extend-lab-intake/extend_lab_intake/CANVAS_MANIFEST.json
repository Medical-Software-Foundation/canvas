        "EXTEND_AI_KEY",
        "EXTEND_AI_PROCESSOR_TREE",
        "ANTHROPIC_API_KEY",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "FHIR_CLIENT_ID",
        "FHIR_CLIENT_SECRET",
        "INBOUND_FAX_TOKEN",
        "CALLBACK_URL"
    ],
