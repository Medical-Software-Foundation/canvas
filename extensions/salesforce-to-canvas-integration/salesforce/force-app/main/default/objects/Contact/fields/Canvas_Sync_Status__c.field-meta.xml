<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Canvas_Sync_Status__c</fullName>
    <label>Canvas Sync Status</label>
    <type>Picklist</type>
    <required>false</required>
    <inlineHelpText>The delivery outcome of the last sync attempt, written by the emitter. Delivered means Canvas accepted it. Retrying means a transient failure that will be retried. Failed means it was given up on, see Canvas Sync Last Error.</inlineHelpText>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Delivered</fullName>
                <default>false</default>
                <label>Delivered</label>
            </value>
            <value>
                <fullName>Retrying</fullName>
                <default>false</default>
                <label>Retrying</label>
            </value>
            <value>
                <fullName>Failed</fullName>
                <default>false</default>
                <label>Failed</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
