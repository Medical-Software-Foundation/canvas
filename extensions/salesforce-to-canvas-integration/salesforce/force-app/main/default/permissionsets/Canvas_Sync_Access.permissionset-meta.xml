<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Canvas Sync Access</label>
    <description>Run access to the emitter so assigned reps can fire the Sync to Canvas and Remove from Canvas buttons, plus read access to the reverse link the plugin writes, the three sync status fields the emitter writes, and the derived Canvas Status badge.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <classAccesses>
        <apexClass>CanvasSyncEmitter</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <fieldPermissions>
        <field>Contact.Canvas_Patient_ID__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Contact.Canvas_Sync_Status__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Contact.Canvas_Sync_Last_Error__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Contact.Canvas_Sync_Last_Attempt__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Contact.Canvas_Status__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
</PermissionSet>
