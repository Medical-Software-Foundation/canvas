{
    "sdk_version": "0.169.1",
    "plugin_version": "0.1.0",
    "name": "portal_content",
    "description": "Patient portal: My Records (visit summaries with After Visit Summary, lab and imaging reports, letters) and My Profile (information and insurance on file).",
    "url_permissions": [],
    "components": {
        "applications": [
            {
                "class": "portal_content.applications.records_app:RecordsApp",
                "name": "My Records",
                "description": "View your visit summaries, lab and imaging reports, and letters.",
                "scope": "portal_menu_item",
                "icon": "assets/records_icon.png",
                "menu_order": 1
            },
            {
                "class": "portal_content.applications.profile_app:ProfileApp",
                "name": "My Profile",
                "description": "View the personal information and insurance Canvas has on file for you.",
                "scope": "portal_menu_item",
                "icon": "assets/profile_icon.png",
                "menu_order": 2
            }
        ],
        "handlers": [
            {
                "class": "portal_content.handlers.portal_api:PortalContentAPI",
                "description": "Serves the portal pages, static assets, and patient-scoped data and document endpoints."
            }
        ],
        "commands": [],
        "content": [],
        "effects": [],
        "views": []
    },
    "variables": [
        {"name": "ENABLED_COMPONENTS", "sensitive": false},
        {"name": "NOTE_TYPES", "sensitive": false},
        {"name": "HOLD_UNREVIEWED_RESULTS", "sensitive": false},
        {"name": "CLIENT_ID", "sensitive": true},
        {"name": "CLIENT_SECRET", "sensitive": true}
    ],
    "tags": {},
    "references": [],
    "license": "MIT",
    "diagram": false,
    "readme": "./README.md"
}
